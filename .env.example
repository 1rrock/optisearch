# ============================================
# 옵티써치 (OptiSearch) - 환경변수 설정
# ============================================
# 이 파일을 .env.local로 복사한 후 값을 채워주세요
# cp .env.example .env.local

# --------------------------------------------
# Supabase
# https://supabase.com/dashboard → 프로젝트 Settings → API
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=              # Project URL (예: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon/public 키
SUPABASE_SERVICE_ROLE_KEY=             # service_role 키 (서버 전용, 절대 클라이언트 노출 금지)
SUPABASE_JWT_SECRET=                   # JWT Secret (Settings → API → JWT Settings)

# --------------------------------------------
# Auth.js (next-auth v5)
# 터미널에서 생성: openssl rand -base64 32
# --------------------------------------------
AUTH_SECRET=                           # Auth.js 암호화 키

# --------------------------------------------
# 네이버 로그인 API
# https://developers.naver.com → 애플리케이션 등록 → "네이버 로그인" 선택
# 콜백 URL 등록: http://localhost:3000/api/auth/callback/naver (개발)
#               https://your-domain.com/api/auth/callback/naver (프로덕션)
# --------------------------------------------
AUTH_NAVER_ID=                         # 네이버 앱 Client ID
AUTH_NAVER_SECRET=                     # 네이버 앱 Client Secret

# --------------------------------------------
# 네이버 검색광고 API
# https://searchad.naver.com → 도구 → API 사용 관리
# 키워드 검색량, 경쟁도, 연관 키워드 조회에 사용
# --------------------------------------------
NAVER_SEARCHAD_CUSTOMER_ID=            # 광고주 ID (숫자)
NAVER_SEARCHAD_ACCESS_LICENSE=         # Access License
NAVER_SEARCHAD_SECRET_KEY=             # Secret Key (HMAC-SHA256 서명에 사용)

# --------------------------------------------
# 네이버 Developers API (검색, 데이터랩)
# https://developers.naver.com → 애플리케이션 등록
# 사용 API: 검색(블로그/카페/지식iN/쇼핑), 데이터랩(트렌드/쇼핑인사이트), 성인판별, 오타교정
# ※ 네이버 로그인 앱과 별도 등록 권장 (API 한도 분리)
# --------------------------------------------
NAVER_CLIENT_ID=                       # Client ID
NAVER_CLIENT_SECRET=                   # Client Secret

# --------------------------------------------
# OpenAI API
# https://platform.openai.com → API Keys
# AI 제목 추천, 글 초안 생성, 콘텐츠 점수 분석에 사용
# 모델: gpt-4o-mini (비용 효율)
# --------------------------------------------
OPENAI_API_KEY=                        # sk-로 시작하는 API 키

# --------------------------------------------
# Vercel Cron
# Vercel이 자동 생성 — 로컬 테스트 시 아무 값이나 설정
# 프로덕션에서는 Vercel이 CRON_SECRET을 자동 주입합니다
# --------------------------------------------
CRON_SECRET=                           # Vercel Cron 인증 시크릿

# --------------------------------------------
# Cloudflare Turnstile (CAPTCHA)
# https://dash.cloudflare.com → Turnstile → 사이트 추가
# 무료 플랜 사용자 키워드 검색 시 CAPTCHA 검증에 사용
# 설정하지 않으면 검증을 건너뜁니다 (graceful degradation)
# --------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=        # 사이트 키 (클라이언트용)
TURNSTILE_SECRET_KEY=                  # 시크릿 키 (서버 전용, 절대 클라이언트 노출 금지)

# --------------------------------------------
# Upstash Redis (Rate Limiting + Cache - optional)
# https://console.upstash.com → Redis → 데이터베이스 생성 → REST API
# 설정하지 않으면 인메모리로 동작합니다 (graceful degradation)
# Vercel KV 사용 시 자동 주입됩니다
# --------------------------------------------
KV_REST_API_URL=                       # Upstash/Vercel KV REST URL
KV_REST_API_TOKEN=                     # Upstash/Vercel KV REST Token

# --------------------------------------------
# 개발 인증 우회 (로컬 개발 전용)
# "true"로 설정하면 Naver 로그인 없이 개발 가능 — 절대 프로덕션에서 사용 금지
# --------------------------------------------
DEV_AUTH_BYPASS=true                   # 개발 환경 인증 우회 (true/false)

# --------------------------------------------
# Paddle 결제 시스템
# https://sandbox-vendors.paddle.com (테스트)
# https://vendors.paddle.com (프로덕션)
# --------------------------------------------
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=       # Paddle 클라이언트 토큰 (test_ 또는 live_)
NEXT_PUBLIC_PADDLE_ENV=sandbox         # sandbox 또는 production
PADDLE_API_KEY=                        # Paddle API 키 (서버 전용)
PADDLE_WEBHOOK_SECRET=                 # Paddle Webhook 시크릿 (Notification 설정에서 확인)

# Paddle Price IDs
NEXT_PUBLIC_PADDLE_PRICE_BASIC=        # 베이직 월간 가격 ID (pri_...)
NEXT_PUBLIC_PADDLE_PRICE_PRO=          # 프로 월간 가격 ID (pri_...)

# --------------------------------------------
# Sentry (optional)
# https://sentry.io → 프로젝트 Settings → Client Keys (DSN)
# 에러 모니터링에 사용 — @sentry/nextjs 패키지 설치 후 활성화
# --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=                # Sentry DSN (예: https://xxx@oyyy.ingest.sentry.io/zzz)
