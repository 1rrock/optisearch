{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/billing",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/collect-keywords",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/collect-ranks",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/collect-trending",
      "schedule": "0 2,6,10,14,18,22 * * *"
    },
    {
      "path": "/api/cron/collect-new-keywords",
      "schedule": "30 19 * * *"
    }
  ]
}
